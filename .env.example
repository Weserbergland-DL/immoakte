# Google Analytics 4 — Measurement-ID (Format: G-XXXXXXXXXX)
# Optional. Wenn nicht gesetzt, läuft die App ganz ohne Tracking.
# Wenn gesetzt, lädt GA trotzdem nur nach aktivem Cookie-Consent.
NEXT_PUBLIC_GA_ID=

