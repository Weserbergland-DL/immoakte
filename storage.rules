rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /feedback/{userId}/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == "info@weserbergland-dienstleistungen.de");
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /signatures/{userId}/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == "info@weserbergland-dienstleistungen.de");
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /protocols/{userId}/{allPaths=**} {
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.email == "info@weserbergland-dienstleistungen.de");
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
